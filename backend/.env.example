GEMINI_API_KEY=
GEMINI_FALLBACK_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.0-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ENABLE_TTS=false

ALLOWED_ORIGINS=http://localhost:5173,https://akashtomy.com
MAX_REQUESTS_PER_IP=10
RATE_LIMIT_WINDOW_SECONDS=86400
RESPONSE_CACHE_MAX_ITEMS=256

CHROMA_DIR=./data/chroma
AUDIO_DIR=./data/audio

# Conversation memory
# Leave REDIS_URL blank to use in-memory session storage (default).
# Set to a Redis connection string to share sessions across workers.
REDIS_URL=
SESSION_MAX_HISTORY=6
SESSION_TTL_SECONDS=3600

# Admin dashboard
ADMIN_ACCESS_TOKEN=

# Cookie signing secret — must be distinct from ADMIN_ACCESS_TOKEN in production.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_COOKIE_SECRET=

# Salt for IP hashing in logs. Required in production (enforced at startup).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
IP_HASH_SALT=

# Set DEV_MODE=true locally so the session cookie works over plain HTTP
# and startup validation for IP_HASH_SALT / ADMIN_COOKIE_SECRET is skipped.
DEV_MODE=false
